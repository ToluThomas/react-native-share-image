{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-native",
    "lib": ["es2020"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "es2020",
    "module": "ES2020",
    "declaration": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "types": ["react-native", "jest"]
  },
  "include": ["src/**/*", "__tests__/**/*", "__mocks__/**/*"],
  "exclude": ["node_modules"]
}
